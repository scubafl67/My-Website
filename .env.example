# Supabase — these are safe to expose in the browser (publishable/anon keys).
# For Netlify, set these in Site settings → Environment variables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile site key (public). Use 1x00000000000000000000AA for local
# testing. The matching SECRET key is configured in the Supabase dashboard, not here.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
